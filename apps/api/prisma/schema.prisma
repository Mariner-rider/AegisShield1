generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  tenants       Tenant[]
  subscriptions Subscription[]
  users         User[]
  createdAt     DateTime       @default(now())
}

model Tenant {
  id              String          @id @default(cuid())
  name            String
  tenantKey       String          @unique
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id])
  projects        Project[]
  apiKeys         ApiKey[]
  detectionEvents DetectionEvent[]
  alerts          Alert[]
  responseActions ResponseAction[]
  auditLogs       AuditLog[]
  policyBundles   PolicyBundle[]
  createdAt       DateTime        @default(now())
}

model Project { id String @id @default(cuid()) tenantId String name String slug String tenant Tenant @relation(fields:[tenantId], references:[id]) environments Environment[] createdAt DateTime @default(now()) }
model Environment { id String @id @default(cuid()) projectId String type String name String project Project @relation(fields:[projectId], references:[id]) createdAt DateTime @default(now()) }
model User { id String @id @default(cuid()) organizationId String email String @unique fullName String passwordHash String role String organization Organization @relation(fields:[organizationId], references:[id]) createdAt DateTime @default(now()) }
model ApiKey { id String @id @default(cuid()) tenantId String label String keyPrefix String secretHash String revokedAt DateTime? tenant Tenant @relation(fields:[tenantId], references:[id]) createdAt DateTime @default(now()) }
model DetectionEvent { id String @id @default(cuid()) tenantId String type String severity Int payload Json tenant Tenant @relation(fields:[tenantId], references:[id]) createdAt DateTime @default(now()) }
model Alert { id String @id @default(cuid()) tenantId String ruleId String severity Int status String tenant Tenant @relation(fields:[tenantId], references:[id]) createdAt DateTime @default(now()) }
model ResponseAction { id String @id @default(cuid()) tenantId String actionType String status String tenant Tenant @relation(fields:[tenantId], references:[id]) createdAt DateTime @default(now()) }
model AuditLog { id String @id @default(cuid()) tenantId String actor String action String metadata Json tenant Tenant @relation(fields:[tenantId], references:[id]) createdAt DateTime @default(now()) }
model PolicyBundle { id String @id @default(cuid()) tenantId String version String signature String tenant Tenant @relation(fields:[tenantId], references:[id]) createdAt DateTime @default(now()) }
model Subscription { id String @id @default(cuid()) organizationId String plan String status String graceUntil DateTime? organization Organization @relation(fields:[organizationId], references:[id]) createdAt DateTime @default(now()) }

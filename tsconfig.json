{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "Node",
    "outDir": "dist"
  },
  "include": ["packages/**/*.ts", "services/**/*.ts", "apps/**/*.ts", "tests/**/*.ts"]
}
